{
  "name": "sinan-han-hotel-booking",
  "version": "1.0.0",
  "description": "Sinan Han Boutique Hotel - Mostar | Booking System Optimized",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "npm run minify:js && npm run minify:css && npm run minify:html",
    "minify:js": "terser SiminHan.js -o SiminHan.min.js -c -m",
    "minify:css": "cleancss -o SinanHan.min.css SinanHan.css",
    "minify:html": "html-minifier --collapse-whitespace --remove-comments --minify-css true --minify-js true SinanHan.html -o SinanHan.min.html",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "hotel",
    "booking",
    "mostar",
    "sinan-han"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "terser": "^5.24.0",
    "clean-css-cli": "^5.6.2",
    "html-minifier": "^4.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
