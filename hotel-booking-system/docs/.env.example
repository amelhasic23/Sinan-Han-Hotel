# Hotel Booking System Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=5000
HOST=localhost
NODE_ENV=production
DEBUG=false

# ==========================================
# BOOKING.COM API (RAPIDAPI)
# Get your key from https://rapidapi.com
# ==========================================
BOOKING_API_KEY=your_rapidapi_key_here
BOOKING_API_HOST=booking-com15.p.rapidapi.com

# ==========================================
# MONRI PAYMENT GATEWAY
# Get credentials from https://monri.com
# ==========================================
MONRI_MERCHANT_ID=your_merchant_id_here
MONRI_MERCHANT_PASSWORD=your_merchant_password_here
MONRI_CHECKOUT_URL=https://gateway.monri.com/auth

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# Example for Gmail:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated password below (NOT your account password)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@example.com

# ==========================================
# CACHING
# ==========================================
CACHE_TTL=3600

# ==========================================
# GOOGLE ANALYTICS 4
# Get your Measurement ID from: https://analytics.google.com
# Format: G-XXXXXXXXXX
# ==========================================
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ==========================================
# OPTIONAL SETTINGS
# ==========================================
# API_TIMEOUT=10000
# LOG_LEVEL=info
