# RapidAPI Configuration for Booking.com Hotel Data
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=booking-com.p.rapidapi.com

# Server Configuration
PORT=5000
NODE_ENV=development

# Hotel Information
HOTEL_ID=123456
HOTEL_NAME=Sinan Han

# Email Configuration (Gmail SMTP)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
BOOKING_REQUEST_EMAIL=about@hotelsinanhan.com

# Monri Payment Gateway Configuration
MONRI_MERCHANT_ID=your_merchant_id
MONRI_API_KEY=your_api_key
MONRI_SECRET_KEY=your_secret_key
MONRI_ENVIRONMENT=test
MONRI_TEST_MODE=true

# Payment Settings
PAYMENT_CURRENCY=BAM
PAYMENT_SUCCESS_REDIRECT=/
PAYMENT_WEBHOOK_SECRET=webhook_signing_key
